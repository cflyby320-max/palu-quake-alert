# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
# Run with:  node --env-file=.env run.js
# NEVER commit the real .env (it is git-ignored).

# --- Location & thresholds (defaults are tuned for Palu; usually leave as-is) -
# PALU_LAT=-0.8917
# PALU_LON=119.8707
# ALERT_RADIUS_KM=350
# MIN_MAGNITUDE=5.0
# POLL_SECONDS=45
# MAX_EVENT_AGE_HOURS=6   # max age (h) for a real-time push; older events only appear in the twice-daily recap
# SHAKEMAP_MIN_MAG=0      # attach the BMKG shakemap image inline whenever BMKG provides one (raise to gate by magnitude)
# SEQUENCE_WINDOW_HOURS=24 # lookback for the "Nth quake near Palu in 24h" aftershock-context line
# DIGEST_ENABLED=true     # twice-daily recap (08:00 & 20:00 WITA), posted from the always-on loop
# DIGEST_HOURS=24         # lookback window for the recap

# --- Seismic Activity Outlook (aftershock-probability heads-up) --------------
# Posts a follow-up "elevated probability" message after a qualifying mainshock.
# Statistical estimate ONLY — never a prediction. See OUTLOOK_DESIGN.md.
# OUTLOOK_ENABLED=true     # kill-switch; set false to stop posting Outlooks
# OUTLOOK_TRIGGER_MAG=5.5  # mainshock magnitude that triggers an Outlook
# OUTLOOK_FELT_MAG=4.0     # "felt aftershock" threshold reported
# OUTLOOK_STRONG_MAG=6.0   # "strong/damaging aftershock" threshold reported
# AFTERSHOCK_A=-1.67       # Reasenberg-Jones productivity (more negative = fewer)
# AFTERSHOCK_B=1.0         # Gutenberg-Richter b-value default
# AFTERSHOCK_P=1.07        # Omori-Utsu decay exponent
# AFTERSHOCK_C=0.05        # Omori-Utsu time offset (days)
# CATALOG_MIN_MAG=3.5      # accumulate near-Palu events at/above this into the local catalog
# CATALOG_RETENTION_DAYS=60

# --- Channel 1: Telegram (RECOMMENDED — free, reliable, easiest) -------------
# 1) In Telegram, message @BotFather -> /newbot -> copy the token below.
# 2) Each relative starts a chat with your new bot and sends any message.
# 3) Get their numeric chat IDs from:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 4) List every relative's chat ID, comma-separated.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# --- Channel 2: Twilio SMS (works without smartphones/data) -------------------
# From https://console.twilio.com  (Account SID + Auth Token + a Twilio number)
# TWILIO_TO is a comma-separated list of relatives' numbers in +62... format.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# --- Channel 3: Twilio WhatsApp (high deliverability in Indonesia) ------------
# Uses the same TWILIO_SID / TWILIO_TOKEN above.
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+62812xxxxxxx,whatsapp:+62813xxxxxxx

# --- Heartbeat / dead-man's-switch (STRONGLY recommended) --------------------
# Create a free check at https://healthchecks.io, paste its ping URL here.
# If this watcher dies, healthchecks.io emails/notifies YOU that it's down.
HEARTBEAT_URL=

# --- Instagram studio (optional; draft cards for manual posting) -------------
# When enabled, each alert also renders a branded card + caption and DMs it to
# YOU (only you) so you can post it to Instagram by hand. Does NOT auto-post and
# does NOT message the family list. Needs studio deps installed (see studio/).
# STUDIO_ENABLED=true
# STUDIO_REVIEW_CHAT_ID=    # your OWN Telegram chat id (start a chat with the bot, then /getUpdates)
# STUDIO_BOT_TOKEN=         # optional; defaults to TELEGRAM_BOT_TOKEN above
#
# Evergreen educational track (studio --edu): preparedness/literacy cards drafted
# between quakes. Captions are pre-authored (no API needed). The OPTIONAL --llm
# flag rephrases a caption via the Claude API (validated; falls back to the
# authored text on any issue), so these two are only needed if you use --llm:
# ANTHROPIC_API_KEY=        # optional; only for `--edu <id> --llm`
# STUDIO_LLM_MODEL=claude-opus-4-8   # optional; model used by --llm
